# MockCraft Environment Configuration Template
# Copy this file to .env and configure as needed.
# Most settings are optional — MockCraft works out of the box.

# Default locale for data generation
# Supported: zh_CN, en_US, ja_JP, ko_KR, zh_TW
MOCKCRAFT_LOCALE=zh_CN

# Default output format (json, csv, table, sql, markdown, yaml)
MOCKCRAFT_FORMAT=table

# Default number of records to generate
MOCKCRAFT_COUNT=10

# Random seed for reproducibility (leave empty for random)
MOCKCRAFT_SEED=

# Output directory for generated files
MOCKCRAFT_OUTPUT_DIR=./output

# SQL table name (for SQL format output)
MOCKCRAFT_SQL_TABLE=mock_data

# Logging level
MOCKCRAFT_LOG_LEVEL=INFO
